# Root-level Markdown (avoids publishing /AGENTS, /CODE_OF_CONDUCT, /SECURITY, etc.)
# Mintlify already ignores README.md, CONTRIBUTING.md, CHANGELOG.md, LICENSE.md by default.
/*.md

# Repo and ops directories (not part of published docs)
scripts/
runbooks/
node_modules/
.github/
.github/*
.github/**

# Top-level config and assets (not doc pages)
# Note: Do not exclude .js or .css. Mintlify loads
# these automatically if present in the content root.

/*.yaml
/*.toml
/*.txt
/package.json
/package-lock.json
/LICENSE
/THIRD-PARTY-NOTICES.txt
