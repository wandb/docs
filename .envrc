# Directory-local dev environment for DocEngine in-repo (Tier-2) testing.
#
# This venv is scoped to THIS directory so the feature-branch engine in the
# docengine/ submodule never collides with the legacy DocEngine monorepo's
# editable install — a venv can hold only one editable install of `docengine`,
# so separate working directories (each with its own .venv) keep them isolated.
#
# Mirrors docengine/.envrc: uv when available, falls back to layout python + pip.
# The one difference is `--project ./docengine`, because the package metadata
# lives in the submodule, not this directory. UV_PROJECT_ENVIRONMENT keeps the
# venv here (./.venv), separate from the submodule's own docengine/.venv.

# Reload when the submodule's dependency surface changes.
watch_file docengine/pyproject.toml
watch_file docengine/uv.lock

REPO_ROOT="$(cd "$(dirname "$DIRENV_FILE")" && pwd)"

# Ensure the engine submodule is present. Only initialize when it is missing so
# reloads stay quiet and a manual `git checkout <sha>` inside the submodule is
# not reset back to the superproject's pinned SHA on every reload.
if [[ ! -e "$REPO_ROOT/docengine/pyproject.toml" ]]; then
  git submodule update --init --quiet docengine
fi

# Warn (without clobbering) when the checked-out submodule differs from the SHA
# the superproject pins — e.g. after a pull bumped the pin. We do not auto-update,
# because that is indistinguishable from an intentional manual `git checkout <sha>`.
# Uses plain echo (not log_status) so the warning survives the empty
# DIRENV_LOG_FORMAT set above.
_pin="$(git -C "$REPO_ROOT" ls-files -s docengine | awk '{print $2}')"
_have="$(git -C "$REPO_ROOT/docengine" rev-parse HEAD 2>/dev/null)"
if [[ -n "$_pin" && -n "$_have" && "$_pin" != "$_have" ]]; then
  echo "direnv: docengine is at ${_have:0:12}, pin is ${_pin:0:12}; run 'git submodule update docengine' to match." >&2
fi

if command -v uv >/dev/null 2>&1; then
  export UV_PROJECT_ENVIRONMENT="$REPO_ROOT/.venv"
  PATH_add "$REPO_ROOT/.venv/bin"
  export VIRTUAL_ENV="$REPO_ROOT/.venv"

  # uv compares the environment against the lock and is a near-silent no-op
  # (~0.2s) when already in sync, so run it every reload. Paired with the
  # watch_file above, this auto-applies dependency bumps when uv.lock changes.
  # Edits under ./docengine/app and `git checkout <sha>` in the submodule are
  # picked up live (editable install).
  uv sync --quiet --project ./docengine --extra dev
else
  layout python python3

  # Reinstall when docengine is missing, OR when the dependency surface
  # (pyproject.toml) changed since the last install. Editable mode picks up code
  # changes live but NOT dependency or entry-point changes, and `pip show` alone
  # never re-runs after the first install — so a pulled submodule SHA with new
  # deps would be silently skipped. Stamp the installed pyproject hash and
  # reinstall on mismatch. If the hash can't be computed, fall back to
  # install-only-if-missing so we never loop reinstalling on every reload.
  _stamp="${VIRTUAL_ENV}/.docengine-pyproject.sha"
  _now="$(git -C "$REPO_ROOT" hash-object docengine/pyproject.toml 2>/dev/null)"
  if ! pip show docengine >/dev/null 2>&1 || { [[ -n "$_now" ]] && [[ "$(cat "$_stamp" 2>/dev/null)" != "$_now" ]]; }; then
    pip install -q -e "./docengine[dev]"
    [[ -n "$_now" ]] && printf '%s' "$_now" > "$_stamp"
  fi
fi
